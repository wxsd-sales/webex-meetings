{
  "name": "webex-meetings",
  "version": "1.0.0",
  "description": "Webex Meetings",
  "scripts": {
    "build": "del dist && parcel build index.html --public-url ./ --no-cache",
    "start": "parcel index.html --open",
    "prod": "parcel index.html",
    "deploy:pages": "gh-pages -d dist/",
    "deploy": "npm run build && npm run deploy:pages"
  },
  "repository": "https://wxsd-sales.github.io/webex-meetings",
  "keywords": [],
  "author": "Rajitha Kantheti",
  "license": "ISC",
  "dependencies": {
    "webex": "^2.60.1"
  },
  "targets": {
    "modern": {
      "engines": {
        "browsers": ">= 50%"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "crypto-browserify": "^3.12.0",
    "gh-pages": "^6.2.0",
    "os-browserify": "^0.3.0",
    "parcel": "^2.12.0",
    "punycode": "^1.4.1",
    "querystring-es3": "^0.2.1",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "url": "^0.11.0",
    "util": "^0.12.3",
    "vm-browserify": "^1.1.2"
  }
